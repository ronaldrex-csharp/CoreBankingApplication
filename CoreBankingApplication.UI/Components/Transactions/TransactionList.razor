@using CoreBankingApplication.Application.ViewModels
@using CoreBankingApplication.Domain.Entities

<div class="table-wrap">
    <table class="bank-table transaction-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Type</th>
                <th class="text-end">Amount</th>
            </tr>
        </thead>
        <tbody>
            @if (Transactions.Any())
            {
                foreach (var t in Transactions)
                {
                    <tr>
                        <td>@t.Date.ToShortDateString()</td>
                        <td>@t.Type</td>
                        
                        <td class="text-end balance-cell @(t.Type == "Withdrawal" ? "text-danger" : "")">
                            @(t.Type == "Withdrawal"? "-" : "")@t.Amount.ToString("C")</td>

                       
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="2" class="empty-row">
                        No transactions found
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public List<TransactionListItemViewModel> Transactions { get; set; } = new();
}
