@page "/"

<PageTitle>Dashboard</PageTitle>

<div class="page-stack">
    <section class="hero-section bank-card">
        <div>
            <div class="eyebrow">Core Banking Platform</div>
            <h1 class="page-title">Welcome back</h1>
            <p class="page-subtitle">
                Review accounts, inspect balances, and manage transaction activity from a clean, secure operations workspace.
            </p>

            <div class="hero-actions">
                <a class="btn btn-bank-primary" href="/accounts">Open Accounts</a>
            </div>
        </div>

        <div class="hero-summary-grid">
            <div class="summary-tile">
                <span class="summary-label">Environment</span>
                <span class="summary-value">Banking Operations</span>
            </div>
            <div class="summary-tile">
                <span class="summary-label">Focus</span>
                <span class="summary-value">Accounts & Transactions</span>
            </div>
        </div>
    </section>

    <section class="dashboard-grid">
        <article class="bank-card info-card">
            <h2>Accounts</h2>
            <p>Access all customer accounts, review balances, and open account-level transaction history.</p>
            <a class="text-link" href="/accounts">Go to Accounts</a>
        </article>

        <article class="bank-card info-card">
            <h2>Transactions</h2>
            <p>Post deposits and withdrawals from the account view with validation and instant UI feedback.</p>
            <span class="muted-note">Available after selecting an account.</span>
        </article>
    </section>
</div>
